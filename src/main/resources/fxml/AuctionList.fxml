<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.2-ea" fx:controller="com.auction.controller.AuctionListController">
    <top>
        <VBox style="-fx-background-color: #2c3e50;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 15;">
                <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="HỆ THỐNG ĐẤU GIÁ TRỰC TUYẾN" />
            </HBox>
            <Label fx:id="userInfoLabel" style="-fx-text-fill: #ecf0f1; -fx-padding: 0 0 10 15; -fx-font-style: italic;" text="Xin chào: ..." />
        </VBox>
    </top>

    <left>
        <VBox prefWidth="200" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-spacing: 10;">
            <Button maxWidth="Infinity" style="-fx-alignment: CENTER_LEFT;" text="Danh sách đấu giá" />
            <Button maxWidth="Infinity" onAction="#handleOpenAddItem" style="-fx-alignment: CENTER_LEFT;" text="Quản lý sản phẩm" />
            <Button maxWidth="Infinity" onAction="#handleOpenHistory" style="-fx-alignment: CENTER_LEFT;" text="Lịch sử giao dịch" />
        </VBox>
    </left>

    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Danh Sách Phiên Đấu Giá Đang Diễn Ra" />
            <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" prefWidth="100" text="Mã SP" />
                    <TableColumn fx:id="colName" prefWidth="200" text="Tên Sản Phẩm" />
                    <TableColumn fx:id="colCurrentPrice" prefWidth="150" text="Giá Hiện Tại" />
                    <TableColumn fx:id="colStatus" prefWidth="120" text="Trạng Thái" />
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <!-- Tăng spacing và ép chiều cao để nút không bị mất -->
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-padding: 15; -fx-background-color: #f4f4f4; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 0;">
            <TextField fx:id="bidAmountField" prefHeight="30.0" prefWidth="150.0" promptText="Nhập giá..." />

            <Button onAction="#handleBidAction" prefHeight="30.0" prefWidth="100.0"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="Đấu giá" />

            <Button fx:id="btnEndAuction" onAction="#handleEndAuction" prefHeight="30.0" prefWidth="130.0"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"
                    text="Kết thúc phiên" />
        </HBox>
    </bottom>
</BorderPane>