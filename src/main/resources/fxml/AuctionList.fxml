<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionListController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10; -fx-background-color: #34495e; -fx-background-radius: 5;">
        <Label fx:id="userInfoLabel" style="-fx-text-fill: white; -fx-font-weight: bold;" text="Đang tải thông tin..." />
    </HBox>

    <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn prefWidth="70.0" text="ID">
                <cellValueFactory>
                    <PropertyValueFactory property="id" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn prefWidth="250.0" text="Tên Sản Phẩm">
                <cellValueFactory>
                    <PropertyValueFactory property="name" />
                </cellValueFactory>
            </TableColumn>
            <TableColumn prefWidth="120.0" text="Giá Hiện Tại">
                <cellValueFactory>
                    <PropertyValueFactory property="currentPrice" />
                </cellValueFactory>
            </TableColumn>
        </columns>
    </TableView>

    <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-padding: 10; -fx-background-color: #f4f4f4; -fx-background-radius: 5;">
        <TextField fx:id="bidAmountField" promptText="Nhập giá đấu..." />
        <Button onAction="#handleBidAction" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="Đấu giá ngay" />

        <Button fx:id="btnEndAuction" onAction="#handleEndAuction" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="Kết thúc phiên" />
    </HBox>
</VBox>